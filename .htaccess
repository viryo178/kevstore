RewriteEngine On

# Google AI Studio / Gemini
# Isi API key dari AI Studio di sini, lalu hapus tanda # di depannya:
# SetEnv GOOGLE_AI_STUDIO_API_KEY "AQ...ATAU_AIza...API_KEY_KAMU"
# SetEnv GOOGLE_AI_STUDIO_MODEL "gemini-2.5-flash"

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php/$1 [L]
